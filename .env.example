# Xero developer app credentials (https://developer.xero.com)
# Create a new app, set redirect URI to: http://localhost:5391/callback
XERO_CLIENT_ID=your_xero_client_id_here
XERO_CLIENT_SECRET=your_xero_client_secret_here

# OAuth callback port (must match the redirect URI registered in Xero)
XERO_REDIRECT_PORT=5391
